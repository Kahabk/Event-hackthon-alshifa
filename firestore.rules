rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          (request.auth.token.email != null
            && request.auth.token.email == 'kahabhns@gmail.com')
          || (
            exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false
          )
        );
    }

    function isJudge() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/judges/$(request.auth.token.email))
        && get(/databases/$(database)/documents/judges/$(request.auth.token.email)).data.active != false;
    }

    function isOwnJudgeDoc(judgeId) {
      return isJudge()
        && judgeId == request.auth.token.email;
    }

    function isOwnJudgeAssignment() {
      return isJudge()
        && resource.data.judgeId == request.auth.token.email;
    }

    function validJudgeScore() {
      return isJudge()
        && request.resource.data.judgeId == request.auth.token.email
        && request.resource.data.assignmentId is string
        && exists(/databases/$(database)/documents/judgeAssignments/$(request.resource.data.assignmentId))
        && get(/databases/$(database)/documents/judgeAssignments/$(request.resource.data.assignmentId)).data.judgeId == request.auth.token.email
        && get(/databases/$(database)/documents/judgeAssignments/$(request.resource.data.assignmentId)).data.teamId == request.resource.data.teamId;
    }

    function validIdeaSubmission() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted']
        && request.resource.data.teamName is string;
    }

    match /registrations/{registrationId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /teamNames/{teamNameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /participantEmails/{emailId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /accountRegistrations/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && userId == request.auth.uid);
      allow create: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /ideaSubmissions/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && userId == request.auth.uid);
      allow create, update: if isSignedIn()
        && userId == request.auth.uid
        && validIdeaSubmission();
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && userId == request.auth.uid);
      allow create, update: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /judges/{judgeId} {
      allow get: if isAdmin() || isOwnJudgeDoc(judgeId);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /judgeAssignments/{assignmentId} {
      allow read: if isAdmin() || isOwnJudgeAssignment();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isOwnJudgeAssignment()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'reviewedAt', 'updatedAt'])
          && request.resource.data.status == 'completed'
        );
    }

    match /scores/{scoreId} {
      allow read: if isAdmin()
        || (isJudge() && resource.data.judgeId == request.auth.token.email);
      allow create, update: if isAdmin() || validJudgeScore();
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && (
          isAdmin()
          || resource.data.target in ['all-users', 'all-teams']
          || resource.data.userId == request.auth.uid
        );
      allow write: if isAdmin();
    }

    match /finalists/{finalistId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
